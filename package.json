{
  "name": "arvia-ui-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter website dev",
    "website": "pnpm --filter website dev",
    "website:build": "pnpm --filter website build",
    "storybook": "pnpm --filter @arvia-ui/react storybook",
    "build": "pnpm --filter './packages/**' -r build",
    "typecheck": "pnpm -r typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "pack:all": "pnpm -r --filter '@arvia-ui/*' exec npm pack"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "pnpm@9.1.2"
}
